# ============================================================
# Apna Fashion Mart - Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git
# ============================================================

# ── Supabase ────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard > Your Project > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here   # SERVER ONLY - never expose to client

# ── Google Maps ─────────────────────────────────────────────
# Get from: https://console.cloud.google.com > APIs & Services > Credentials
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ── Razorpay Payments ────────────────────────────────────────
# Get from: https://dashboard.razorpay.com > Settings > API Keys
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_your-key-id
RAZORPAY_KEY_SECRET=your-razorpay-secret             # SERVER ONLY

# ── Cloudflare ───────────────────────────────────────────────
# Used only for local wrangler commands — NOT needed in .env.local for app
# CLOUDFLARE_API_TOKEN=set-in-github-secrets
# CLOUDFLARE_ACCOUNT_ID=set-in-github-secrets

# ── App Config ───────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://apnafashionmart.com
NEXT_PUBLIC_APP_NAME="Apna Fashion Mart"

# ── Cloudflare R2 (Image Storage) ────────────────────────────
# Get from: https://dash.cloudflare.com > R2 > Manage R2 API Tokens
CLOUDFLARE_R2_ACCOUNT_ID=your-r2-account-id
CLOUDFLARE_R2_ACCESS_KEY_ID=your-r2-access-key
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your-r2-secret-key
NEXT_PUBLIC_R2_PUBLIC_URL=https://pub-xxx.r2.dev         # Public bucket URL
